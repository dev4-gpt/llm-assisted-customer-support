# ─── LLM (default: hosted OpenAI-compatible API) ───────────────────────────
# You can keep all keys here and switch with ONE variable:
#   LLM_PROFILE=ollama | openrouter | nvidia | manual
LLM_PROFILE=openrouter

# Manual mode only (ignored when profile != manual):
LLM_PROVIDER=openai_compatible
LLM_MODEL=google/gemini-2.0-flash-exp:free
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2

# Manual mode endpoint + key (ignored when profile != manual):
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_API_KEY=replace-with-real-api-key

# Profile slots (recommended):
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
NVIDIA_API_KEY=replace-with-nvidia-key
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
OLLAMA_MODEL=qwen2.5:7b-instruct

# Local Ollama alternative (if desired):
# LLM_PROVIDER=ollama
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_COMPATIBLE_API_KEY=ollama
# LLM_MODEL=llama3.2

# Prompt / rubric version (Prometheus label on LLM metrics)
# LLM_PROMPT_VERSION=v1

# Optional: Anthropic cloud (requires: pip install anthropic)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# ─── Application ──────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=false
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
APP_SECRET_KEY=change-me-in-production

# ─── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RATE_LIMIT_PER_MINUTE=60

# ─── Redis (caching + rate limiting) ──────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

# ─── Quality Thresholds ───────────────────────────────────────
QUALITY_PASS_THRESHOLD=0.70
# Escalation team override when sentiment is strictly below this (high/critical only)
SENTIMENT_ESCALATION_CUTOFF=-0.6

# ─── RAG (local policy JSON for /api/v1/rag/context) ─────────
# POLICY_SNIPPETS_PATH=data/policy_snippets.json
# RAG_BACKEND=lexical
# RAG_BACKEND=embedding
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# pip install -e ".[embedding]" for embedding backend

# ─── Policy grounding (0 = off) ──────────────────────────────
# QUALITY_POLICY_CONTEXT_TOP_K=3
# TRIAGE_POLICY_CONTEXT_TOP_K=2

# ─── Hybrid triage (optional joblib from train_encoder_classifier.py) ─
# TRIAGE_HYBRID_ENABLED=false
# TRIAGE_BASELINE_MODEL_PATH=artifacts/triage_baseline.joblib

# ─── Optional fine-tuned BERT/RoBERTa hint (pip install -e ".[transformer]") ─
# TRIAGE_TRANSFORMER_ENABLED=false
# TRIAGE_TRANSFORMER_MODEL_DIR=artifacts/triage_roberta

# ─── Invalid-label recovery (recommended for hosted LLM demos) ───────────────
# If LLM emits off-schema labels (e.g., "refund"), map to the allowed taxonomy.
TRIAGE_EMBEDDING_FALLBACK_ENABLED=true
TRIAGE_EMBEDDING_MODEL=all-MiniLM-L6-v2
TRIAGE_EMBEDDING_MIN_SIMILARITY=0.22

# ─── API hardening ───────────────────────────────────────────
# API_KEYS=key-one,key-two
# AUDIT_LOG_PATH=artifacts/audit.jsonl
# TRIAGE_API_KEY=key-one   # for zendesk_worker --api-key default

# ─── SLA (minutes) ───────────────────────────────────────────
SLA_CRITICAL_MINUTES=15
SLA_HIGH_MINUTES=60
SLA_MEDIUM_MINUTES=240
SLA_LOW_MINUTES=1440

# ─── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=support-triage
METRICS_ENABLED=true
